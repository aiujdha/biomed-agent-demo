# Environment
# No API keys required for default configuration.

# LLM provider: "fake" (default, no key needed) or "openai-compatible"
# LLM_PROVIDER=fake

# API key for openai-compatible provider (required when LLM_PROVIDER=openai-compatible)
# LLM_API_KEY=

# Base URL for openai-compatible provider
# LLM_BASE_URL=https://api.openai.com/v1

# Model name for openai-compatible provider
# LLM_MODEL=gpt-4o-mini
